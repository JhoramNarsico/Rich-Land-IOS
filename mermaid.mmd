flowchart TD
    %% --- Styling Definitions ---
    classDef client fill:#e1f5fe,stroke:#03a9f4,stroke-width:2px,color:#333;
    classDef network fill:#fff3e0,stroke:#ff9800,stroke-width:2px,color:#333;
    classDef server fill:#e8f5e9,stroke:#4caf50,stroke-width:2px,color:#333;
    classDef database fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px,color:#333;
    classDef git fill:#fbe9e7,stroke:#ff5722,stroke-width:2px,color:#333;

    %% --- Component Layers ---

    subgraph " "
        GIT["🐙 Git Repository"]:::git
    end

    subgraph "CLIENT"
        C["💻 End-Users (POS & Admin via Web Browser)"]:::client
    end

    subgraph "NETWORK (Render)"
        N["🌐 Load Balancer & CDN (Handles HTTPS, SSL, and Routing)"]:::network
    end

    subgraph "SERVER (Render Compute)"
        S["⚙️ Web Service (Runs Django/Gunicorn App Logic)"]:::server
    end

    subgraph "DATABASE (Render Storage)"
        D1[("🐘 PostgreSQL (Primary Data)")]:::database
        D2[("⚡ Redis (Cache & Sessions)")]:::database
    end

    %% --- Connections & Data Flow ---

    %% 1. User Request Flow
    C -- "1. HTTPS Request" --> N
    N -- "2. Forwards Request" --> S
    
    %% 2. Server-Side Processing
    S -- "3. Reads/Writes Data" --> D1
    S -- "4. Caches Data" --> D2
    
    %% 3. Response Flow
    D1 -- "Data" --> S
    D2 -- "Cached Data" --> S
    S -- "5. Sends Response" --> N
    N -- "6. Returns Content to User" --> C

    %% 4. Deployment Flow
    GIT -- "CI/CD: Push to Deploy" --> S